{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist/lib/hubert",
    "noEmit": true,
    "lib": [
      "esnext",
      "dom",
      "dom.iterable"
    ],
    "isolatedModules": true,
    "incremental": true,
    "resolveJsonModule": true,
    "module": "nodenext",
    "paths": {
      "@lotta-schule/theme": [
        "../theme/src/index.js"
      ],
      "#/*": [
        "./src/*"
      ]
    }
  },
  "references": [
    {
      "path": "./tsconfig.test.json"
    },
    {
      "path": "./tsconfig.lib.json"
    }
  ],
  "include": []
}
