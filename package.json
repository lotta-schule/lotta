{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@lotta-schule/lotta",
  "description": "Lotta Web Monorepo",
  "homepage": "https://lotta.schule",
  "scripts": {
    "dev": "nx run-many --target=dev --parallel --exclude core-api",
    "dev:full": "nx run-many --target=dev --parallel",
    "test": "nx run-many --target=test --parallel",
    "lint": "nx run-many --target=lint --parallel",
    "typecheck": "nx run-many --target=typecheck --parallel",
    "release:prepare": "./scripts/release.sh",
    "nx": "nx",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@nx/js": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@react-types/checkbox": "^3.11.0",
    "@react-types/progress": "^3.6.0",
    "@react-types/shared": "^3.36.0",
    "@rollup/plugin-graphql": "^3.0.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.43",
    "@swc/helpers": "~0.5.23",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/absinthe__socket": "^0.2.6",
    "@types/absinthe__socket-apollo-link": "^0.2.1",
    "@types/cookies": "^0.9.2",
    "@types/file-saver": "^2.0.7",
    "@types/is-url": "^1.2.32",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.0.1",
    "@types/phoenix": "^1.6.7",
    "@types/react": "^19.2.17",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.2.3",
    "@types/slate-base64-serializer": "^0.2.5",
    "@types/user-event": "^4.1.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-istanbul": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "chromium-bidi": "^16.0.1",
    "concurrently": "^10.0.3",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "graphql-tag": "^2.12.7",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lerna": "^9.0.7",
    "lint-staged": "^17.0.8",
    "nx": "23.0.1",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-dts": "5.0.3",
    "vite-plugin-externalize-deps": "^0.10.0",
    "vitest": "^4.1.9"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "libs/*",
    "apps/*"
  ],
  "lint-staged": {
    "$schema": "https://json.schemastore.org/lint-staged",
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ],
    "*.{graphql,gql}": [
      "prettier --write"
    ],
    "*.{html,xml}": [
      "prettier --write"
    ],
    "*.{ex,exs,eex,heex}": [
      "mix format"
    ]
  },
  "overrides": {
    "react-is": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
