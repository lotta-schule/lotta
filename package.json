{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@lotta-schule/lotta",
  "description": "Lotta Web Monorepo",
  "homepage": "https://lotta.schule",
  "scripts": {
    "dev": "nx run-many --target=dev --parallel --exclude core-api",
    "dev:full": "nx run-many --target=dev --parallel",
    "test": "nx run-many --target=test --parallel",
    "lint": "nx run-many --target=lint --parallel",
    "typecheck": "nx run-many --target=typecheck --parallel",
    "release:prepare": "./scripts/release.sh",
    "nx": "nx",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^15.5.18",
    "@nx/js": "19.5.3",
    "@nx/workspace": "19.5.3",
    "@react-types/checkbox": "^3.11.0",
    "@react-types/progress": "^3.6.0",
    "@react-types/shared": "^3.34.0",
    "@rollup/plugin-graphql": "^2.0.5",
    "@swc-node/register": "~1.10.10",
    "@swc/core": "~1.11.31",
    "@swc/helpers": "~0.5.21",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/absinthe__socket": "^0.2.6",
    "@types/absinthe__socket-apollo-link": "^0.2.1",
    "@types/cookies": "^0.9.2",
    "@types/file-saver": "^2.0.7",
    "@types/is-url": "^1.2.32",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.19.19",
    "@types/phoenix": "^1.6.7",
    "@types/react": "^19.2.15",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.2.3",
    "@types/slate-base64-serializer": "^0.2.5",
    "@types/user-event": "^4.1.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-istanbul": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "beta",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-storybook": "^0.11.6",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-vitest": "0.5.4",
    "graphql-tag": "^2.12.6",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lerna": "^8.2.4",
    "lint-staged": "^15.5.2",
    "nx": "20.4.6",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^5.4.21",
    "vite-plugin-dts": "4.5.1",
    "vite-plugin-externalize-deps": "^0.9.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "overrides": {
      "eslint": "^9.0.0"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@sentry/cli",
      "@swc/core",
      "esbuild",
      "nx",
      "sharp"
    ],
    "patchedDependencies": {
      "next": "patches/next.patch"
    }
  },
  "lint-staged": {
    "$schema": "https://json.schemastore.org/lint-staged",
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ],
    "*.{graphql,gql}": [
      "prettier --write"
    ],
    "*.{html,xml}": [
      "prettier --write"
    ],
    "*.{ex,exs,eex,heex}": [
      "mix format"
    ]
  }
}
