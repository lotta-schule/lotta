{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  // Type-checking config, decoupled from the build.
  //
  // The build (`next build` / Turbopack) uses `tsconfig.json` with
  // `moduleResolution: nodenext` — required so Turbopack rewrites the `.js`
  // import specifiers used by the source-consumed `hubert`/`theme` libs.
  // tsc under nodenext, however, cannot resolve Next 16's `exports`-less
  // `next/*` subpaths, so the build's inline type-check is disabled
  // (`typescript.ignoreBuildErrors` in next.config.js) and real type-checking
  // happens here under `moduleResolution: bundler`, which resolves `next/*`,
  // the workspace libs, and `.js`→`.ts` correctly.
  //
  // See TYPECHECK_MIGRATION_PLAN.md for the full rationale.
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "rootDir": "../..",
    "types": ["node"]
  },
  "references": [],
  "files": [],
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "src/test/**"]
}
