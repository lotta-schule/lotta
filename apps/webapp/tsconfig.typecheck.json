{
  "$schema": "http://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  // Whole-`src` type-check under `moduleResolution: bundler`.
  //
  // The build (`next build` / Turbopack) uses `tsconfig.json` with nodenext —
  // required so Turbopack rewrites the `.js` specifiers of the source-consumed
  // `hubert`/`theme` libs. tsc under nodenext, however, can't type-check Next code:
  // even with explicit `.js` on `next/*` imports (which makes them *resolve*),
  // Next's own `.d.ts` files use extensionless relative imports that nodenext
  // can't follow, breaking the types of Next's default exports (e.g. `next/link`).
  // So the build's inline type-check stays disabled (`ignoreBuildErrors`) and real
  // type-checking happens here under `bundler`, which handles `next/*`, the
  // workspace libs, and `.js`→`.ts` correctly. See TYPECHECK_MIGRATION_PLAN.md.
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "rootDir": "../..",
    "types": ["node"]
  },
  "references": [],
  "files": [],
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "src/test/**"]
}
