{
  "$schema": "https://raw.githubusercontent.com/SchemaStore/schemastore/master/src/schemas/json/package.json",
  "name": "@lotta-schule/webapp",
  "version": "6.1.21",
  "description": "Lotta Schule Webapp",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "next dev",
    "start:prod": "next start",
    "build": "next build",
    "test": "vitest run",
    "lint": "oxlint --fix src/ --format $([[ -n $GITHUB_ACTIONS ]] && echo 'github' || echo 'default')",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "schema:download": "bunx get-graphql-schema http://127.0.0.1:4000/api > .tmp/schema.graphql",
    "translations:collect": "bunx i18next"
  },
  "type": "module",
  "dependencies": {
    "@absinthe/socket": "^0.2.1",
    "@absinthe/socket-apollo-link": "^0.2.1",
    "@apollo/client": "^4.2.3",
    "@apollo/client-integration-nextjs": "^0.14.5",
    "@apollo/link-error": "2.0.0-beta.3",
    "@epic-web/invariant": "^1.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-regular-svg-icons": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@ptitmouton/app-config": "^0.0.2",
    "@sentry/nextjs": "^10.62.0",
    "@vercel/otel": "^2.1.3",
    "apollo-v3-absinthe-upload-link": "^1.6.0",
    "axios": "^1.18.1",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "cookie-es": "^3.1.1",
    "cookies": "^0.9.1",
    "date-fns": "^4.4.0",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.42.0",
    "gql.tada": "^1.11.2",
    "graphql": "^17.0.1",
    "http-proxy-middleware": "^3.0.5",
    "i18next": "^26.3.3",
    "import-in-the-middle": "^3.2.0",
    "is-url": "^1.2.4",
    "jwt-decode": "^4.0.0",
    "lodash": "^4.18.1",
    "next": "16.2.9",
    "next-logger": "^5.0.2",
    "phoenix": "^1.8.8",
    "pino": "^10.3.1",
    "react": "^19.2.7",
    "react-big-calendar": "^1.20.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-use": "^17.6.1",
    "require-in-the-middle": "^8.0.1",
    "slate": "^0.76.1",
    "slate-react": "^0.76.1",
    "slugify": "^1.6.9"
  },
  "devDependencies": {
    "i18next-parser": "^9.4.0",
    "ignore-loader": "^0.1.2",
    "sass": "^1.101.0",
    "vitest": "^4.1.9",
    "vitest-browser-react": "^2.2.0"
  },
  "packageManager": "bun@1.3.14",
  "lint-staged": {
    "$schema": "https://json.schemastore.org/lint-staged",
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ],
    "*.{graphql,gql}": [
      "prettier --write"
    ],
    "*.{html,xml}": [
      "prettier --write"
    ]
  }
}
