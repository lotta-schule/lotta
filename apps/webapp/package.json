{
  "$schema": "https://raw.githubusercontent.com/SchemaStore/schemastore/master/src/schemas/json/package.json",
  "name": "@lotta-schule/webapp",
  "version": "6.1.21",
  "description": "Lotta Schule Webapp",
  "scripts": {
    "dev": "next dev",
    "start:prod": "next start",
    "build": "next build",
    "test": "vitest run",
    "lint": "eslint 'src/**/*.*' --no-warn-ignored --fix",
    "typecheck": "tsc --noEmit",
    "schema:download": "pnpm dlx get-graphql-schema http://127.0.0.1:4000/api > .tmp/schema.graphql",
    "translations:collect": "pnpm i18next"
  },
  "type": "module",
  "dependencies": {
    "@absinthe/socket": "catalog:",
    "@absinthe/socket-apollo-link": "catalog:",
    "@apollo/client": "catalog:",
    "@apollo/client-integration-nextjs": "catalog:",
    "@apollo/link-error": "2.0.0-beta.3",
    "@epic-web/invariant": "catalog:",
    "@fortawesome/fontawesome-svg-core": "catalog:",
    "@fortawesome/free-regular-svg-icons": "catalog:",
    "@fortawesome/free-solid-svg-icons": "catalog:",
    "@fortawesome/react-fontawesome": "catalog:",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.74.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.216.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.216.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@ptitmouton/app-config": "catalog:",
    "@sentry/nextjs": "^10.51.0",
    "@vercel/otel": "catalog:",
    "apollo-v3-absinthe-upload-link": "catalog:",
    "axios": "catalog:",
    "chart.js": "^4.5.1",
    "clsx": "catalog:",
    "cookie-es": "catalog:",
    "cookies": "catalog:",
    "date-fns": "catalog:",
    "file-saver": "catalog:",
    "framer-motion": "catalog:",
    "gql.tada": "catalog:",
    "graphql": "catalog:",
    "http-proxy-middleware": "catalog:",
    "i18next": "catalog:",
    "import-in-the-middle": "catalog:",
    "is-url": "catalog:",
    "jwt-decode": "catalog:",
    "lodash": "catalog:",
    "next": "catalog:",
    "next-logger": "^5.0.2",
    "phoenix": "catalog:",
    "pino": "^10.3.1",
    "react": "catalog:",
    "react-big-calendar": "catalog:",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "catalog:",
    "react-i18next": "catalog:",
    "react-use": "catalog:",
    "require-in-the-middle": "catalog:",
    "slate": "catalog:",
    "slate-react": "catalog:",
    "slugify": "catalog:"
  },
  "devDependencies": {
    "i18next-parser": "catalog:",
    "ignore-loader": "catalog:",
    "sass": "catalog:",
    "vitest": "catalog:",
    "vitest-browser-react": "^2.2.0"
  },
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  },
  "lint-staged": {
    "$schema": "https://json.schemastore.org/lint-staged",
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ],
    "*.{graphql,gql}": [
      "prettier --write"
    ],
    "*.{html,xml}": [
      "prettier --write"
    ]
  }
}
